# RoadReach — Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.

# ZohoMail SMTP credentials
ZOHO_EMAIL=info@roadreach.co.za
ZOHO_PASSWORD=your-zohomail-app-password-here

# Where form submissions are forwarded (defaults to ZOHO_EMAIL if not set)
CONTACT_EMAIL=info@roadreach.co.za
