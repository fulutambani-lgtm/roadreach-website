{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog",
      "destination": "/blog/",
      "permanent": true
    },
    {
      "source": "/driver-apply",
      "destination": "/driver-application",
      "permanent": true
    },
    {
      "source": "/driver-terms-and-conditions",
      "destination": "/driver-terms",
      "permanent": true
    },
    {
      "source": "/passive-income-drivers",
      "destination": "/drivers",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:page",
      "destination": "/:page.html"
    }
  ]
}
